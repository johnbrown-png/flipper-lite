# Example Environment Configuration for Scheduled Extraction
# Copy this to .env and fill in your actual values

# Required: YouTube API Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# Required: OpenAI API Key (for embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Email Notifications
# Uncomment and fill in to enable email alerts for IP blocks and completion
#NOTIFICATION_EMAIL=your@email.com
#SMTP_SERVER=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USERNAME=your@email.com
#SMTP_PASSWORD=your_app_password_here

# Pipeline Configuration (Optional - has defaults)
#MAX_VIDEOS_PER_CHANNEL=20
#VIDEOS_PER_BATCH=5
#RANDOM_DELAY_MIN=8.0
#RANDOM_DELAY_MAX=15.0
#BREAK_DURATION_MIN=120.0
#BREAK_DURATION_MAX=300.0

# Embedding Configuration (Optional - has defaults)
#EMBEDDING_MODEL=text-embedding-3-large
#EMBEDDING_DIMENSIONS=3072
